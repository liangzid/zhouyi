/* pages/result/result.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  padding: 40rpx 30rpx 60rpx;
  box-sizing: border-box;
}

/* 问事信息 */
.question-info {
  background: rgba(232, 213, 183, 0.08);
  border: 1rpx solid rgba(232, 213, 183, 0.2);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.question-header {
  font-size: 30rpx;
  color: #e8d5b7;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid rgba(232, 213, 183, 0.15);
}

.question-item {
  display: flex;
  margin-bottom: 15rpx;
}

.question-item:last-child {
  margin-bottom: 0;
}

.question-label {
  font-size: 26rpx;
  color: #888;
  min-width: 140rpx;
}

.question-value {
  font-size: 26rpx;
  color: #e8d5b7;
  flex: 1;
}

/* 卦象显示 */
.gua-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  border-bottom: 1rpx solid rgba(232, 213, 183, 0.1);
  margin-bottom: 30rpx;
}

.gua-symbol {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.symbol-text {
  font-size: 72rpx;
  color: #e8d5b7;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.symbol-icon {
  font-size: 48rpx;
  color: #c9a86c;
  letter-spacing: 20rpx;
}

.gua-info {
  text-align: center;
}

.gua-name {
  font-size: 40rpx;
  color: #e8d5b7;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.gua-xiang {
  font-size: 26rpx;
  color: #888;
}

.bian-tip {
  margin-top: 20rpx;
  padding: 12rpx 24rpx;
  background: rgba(232, 213, 183, 0.1);
  border-radius: 20rpx;
}

.bian-tip text {
  font-size: 24rpx;
  color: #e8d5b7;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 30rpx;
}

.tab-item {
  font-size: 30rpx;
  color: #666;
  padding: 16rpx 30rpx;
  border-radius: 30rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #e8d5b7;
  background: rgba(232, 213, 183, 0.15);
}

/* 六爻显示 */
.yao-display {
  margin-bottom: 30rpx;
}

.yao-title {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 16rpx;
}

.yao-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}

.yao-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 8rpx;
}

.yao-name {
  font-size: 24rpx;
  color: #888;
}

.yao-type {
  font-size: 26rpx;
  color: #e8d5b7;
}

.yao-type.bian {
  color: #ff6b6b;
}

/* 八卦卦象显示 */
.bagua-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
}

.bagua-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.bagua-label {
  font-size: 28rpx;
  color: #c9a86c;
  font-weight: bold;
}

.bagua-yaos {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bagua-yao-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  cursor: pointer;
}

.yao-line {
  width: 200rpx;
  height: 12rpx;
  border-radius: 6rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.yao-line.yang {
  background: #e8d5b7;
}

.yao-line.yin {
  background: transparent;
  border: none;
  height: 12rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.yao-line.yin::before,
.yao-line.yin::after {
  content: '';
  width: 80rpx;
  height: 4rpx;
  background: #e8d5b7;
  border-radius: 2rpx;
}

.yao-line.bian-yao {
  box-shadow: 0 0 10rpx rgba(255, 107, 107, 0.5);
}

.yao-line.changed {
  box-shadow: 0 0 15rpx rgba(255, 149, 0, 0.6);
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.bian-mark {
  position: absolute;
  right: -40rpx;
  font-size: 20rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.bagua-divider {
  width: 200rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(201, 168, 108, 0.5), transparent);
  margin: 10rpx 0;
}

/* 爻辞弹窗 */
.yao-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.yao-popup-content {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  border: 1rpx solid rgba(201, 168, 108, 0.3);
  border-radius: 24rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}

.yao-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(201, 168, 108, 0.2);
}

.yao-popup-title {
  font-size: 36rpx;
  color: #e8d5b7;
  font-weight: bold;
}

.yao-popup-type {
  font-size: 26rpx;
  color: #e8d5b7;
}

.yao-popup-type.bian {
  color: #ff6b6b;
}

.yao-popup-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 30rpx;
}

.yao-popup-line {
  width: 240rpx;
  height: 16rpx;
  border-radius: 8rpx;
}

.yao-popup-line.yang {
  background: #e8d5b7;
}

.yao-popup-line.yin {
  background: transparent;
  border: none;
  height: 16rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.yao-popup-line.yin::before,
.yao-popup-line.yin::after {
  content: '';
  width: 100rpx;
  height: 5rpx;
  background: #e8d5b7;
  border-radius: 3rpx;
}

.yao-popup-ci {
  font-size: 28rpx;
  color: #b0b0b0;
  line-height: 1.9;
  text-align: center;
}

.yao-popup-close {
  text-align: center;
  font-size: 26rpx;
  color: #666;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(201, 168, 108, 0.1);
}

/* 内容区块 */
.content-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  color: #c9a86c;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #c9a86c;
}

.section-content {
  font-size: 26rpx;
  color: #b0b0b0;
  line-height: 1.9;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.02);
  border-radius: 12rpx;
}

.gua-ci {
  font-size: 28rpx;
  color: #e8d5b7;
  font-weight: 500;
}

/* 爻辞列表 */
.yao-ci-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.yao-ci-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.02);
  border-radius: 8rpx;
}

.yao-ci-label {
  font-size: 24rpx;
  color: #c9a86c;
  min-width: 60rpx;
}

.yao-ci-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
  flex: 1;
}

/* 操作按钮 */
.action-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.copy-btn,
.share-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
}

.copy-btn {
  background: rgba(232, 213, 183, 0.15);
  color: #e8d5b7;
  border: 1rpx solid rgba(232, 213, 183, 0.3);
}

.share-btn {
  background: linear-gradient(135deg, #e8d5b7 0%, #c9a86c 100%);
  color: #1a1a2e;
  font-weight: bold;
}

/* 复制成功弹窗 */
.copy-success-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.copy-success-content {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  border: 1rpx solid rgba(201, 168, 108, 0.3);
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  width: 80%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.copy-success-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4ade80 0%, #22c55e 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  color: #fff;
  margin-bottom: 30rpx;
}

.copy-success-title {
  font-size: 36rpx;
  color: #e8d5b7;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.copy-success-desc {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 24rpx;
}

.copy-success-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.copy-success-item {
  padding: 12rpx 24rpx;
  background: rgba(232, 213, 183, 0.1);
  border: 1rpx solid rgba(232, 213, 183, 0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #e8d5b7;
}

.copy-success-tip {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.copy-success-close {
  text-align: center;
  font-size: 24rpx;
  color: #555;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(201, 168, 108, 0.1);
}
