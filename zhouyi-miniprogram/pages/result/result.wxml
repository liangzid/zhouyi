<!--pages/result/result.wxml-->
<view class="container">
  <!-- 问事信息 -->
  <view class="question-info" wx:if="{{showQuestionInfo && questionInfo}}">
    <view class="question-header">本次问事</view>
    <view class="question-item">
      <text class="question-label">所问何事：</text>
      <text class="question-value">{{questionInfo.event}}</text>
    </view>
    <view class="question-item">
      <text class="question-label">所在地点：</text>
      <text class="question-value">{{questionInfo.locationText || '未填写'}}</text>
    </view>
    <view class="question-item">
      <text class="question-label">当前时间：</text>
      <text class="question-value">{{questionInfo.currentTime || '未填写'}}</text>
    </view>
    <view class="question-item">
      <text class="question-label">目标时间：</text>
      <text class="question-value">{{questionInfo.targetTime || '未填写'}}</text>
    </view>
  </view>

  <!-- 卦象显示 -->
  <view class="gua-display">
    <!-- 卦名和解释 -->
    <view class="gua-info">
      <view class="gua-name {{currentTab === 1 ? 'bian-gua' : ''}}">{{currentTab === 0 ? guaDetail.guaName : bianGuaDetail.guaName}}卦</view>
      <view class="gua-xiang {{currentTab === 1 ? 'bian-gua' : ''}}">{{currentTab === 0 ? guaDetail.guaXiang : bianGuaDetail.guaXiang}}</view>
    </view>

    <!-- 变卦提示 -->
    <view class="bian-tip" wx:if="{{hasBian}}">
      <text>本卦 {{guaDetail.guaName}} → 变卦 {{bianGuaDetail.guaName}}</text>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar" wx:if="{{hasBian}}">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
      本卦
    </view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
      变卦
    </view>
  </view>

  <!-- 八卦卦象（竖向显示） -->
  <view class="bagua-display">
    <!-- 上卦：四爻、五爻、上爻 -->
    <view class="bagua-item">
      <view class="bagua-label">上卦 · {{currentTab === 0 ? guaDetail.upperGua : bianGuaDetail.upperGua}}</view>
      <view class="bagua-yaos">
        <block wx:for="{{currentTab === 0 ? upperYaoResults : upperYaoResultsBian}}" wx:key="index">
          <view class="bagua-yao-item" bindtap="showYaoCi" data-index="{{index + 3}}" data-type="{{item.type}}" data-yao="{{item.yao}}">
            <view class="yao-line {{item.yao === 1 ? 'yang' : 'yin'}} {{item.type === '老阳' || item.type === '老阴' ? 'bian-yao' : ''}}">
              <text wx:if="{{item.type === '老阳' || item.type === '老阴'}}" class="bian-mark">变</text>
            </view>
            <text class="yao-name">{{yaoTypes[index + 3]}}</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 分隔线 -->
    <view class="bagua-divider"></view>

    <!-- 下卦：初爻、二爻、三爻 -->
    <view class="bagua-item">
      <view class="bagua-label">下卦 · {{currentTab === 0 ? guaDetail.lowerGua : bianGuaDetail.lowerGua}}</view>
      <view class="bagua-yaos">
        <block wx:for="{{currentTab === 0 ? lowerYaoResults : lowerYaoResultsBian}}" wx:key="index">
          <view class="bagua-yao-item" bindtap="showYaoCi" data-index="{{index}}" data-type="{{item.type}}" data-yao="{{item.yao}}">
            <view class="yao-line {{item.yao === 1 ? 'yang' : 'yin'}} {{item.type === '老阳' || item.type === '老阴' ? 'bian-yao' : ''}}">
              <text wx:if="{{item.type === '老阳' || item.type === '老阴'}}" class="bian-mark">变</text>
            </view>
            <text class="yao-name">{{yaoTypes[index]}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <!-- 卦辞区域 -->
  <view class="content-section">
    <view class="section-title">卦辞</view>
    <view class="section-content gua-ci">
      {{currentTab === 0 ? guaDetail.guaCi : bianGuaDetail.guaCi}}
    </view>
  </view>

  <!-- 彖传 -->
  <view class="content-section">
    <view class="section-title">彖传</view>
    <view class="section-content">
      {{currentTab === 0 ? guaDetail.duan : bianGuaDetail.duan}}
    </view>
  </view>

  <!-- 大象传 -->
  <view class="content-section">
    <view class="section-title">大象传</view>
    <view class="section-content">
      {{currentTab === 0 ? guaDetail.xiang : bianGuaDetail.xiang}}
    </view>
  </view>

  <!-- 爻辞列表 -->
  <view class="content-section">
    <view class="section-title">爻辞</view>
    <view class="yao-ci-list">
      <block wx:for="{{currentTab === 0 ? guaDetail.yaoCi : bianGuaDetail.yaoCi}}" wx:key="index">
        <view class="yao-ci-item">
          <text class="yao-ci-label">{{yaoTypes[index]}}</text>
          <text class="yao-ci-text">{{item}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-btns">
    <button class="copy-btn" bindtap="copyGuaCi">复制结果</button>
    <button class="share-btn" bindtap="showShareTip">分享结果</button>
  </view>

  <!-- 分享提示弹窗 -->
  <view class="share-tip-popup" wx:if="{{showShareTip}}" bindtap="closeShareTip">
    <view class="share-tip-content" catchtap="true">
      <view class="share-tip-title">分享方式</view>
      <view class="share-tip-desc">您可以选择以下方式分享本次占卜结果：</view>
      <view class="share-tip-btns">
        <button class="share-tip-btn share-card-btn" bindtap="doShareCard">分享小程序卡片</button>
        <button class="share-tip-btn share-img-btn" bindtap="doShareImage">保存到相册</button>
      </view>
      <view class="share-tip-cancel" bindtap="closeShareTip">取消</view>
    </view>
  </view>

  <!-- 隐藏的 Canvas 用于生图，4倍分辨率确保清晰度 -->
  <canvas canvas-id="shareCanvas" class="share-canvas" style="width:750rpx;height:3200rpx;" canvas-width="3000" canvas-height="12800"></canvas>

  <!-- 爻辞弹窗 -->
  <view class="yao-popup" wx:if="{{showYaoPopup}}" bindtap="closeYaoPopup">
    <view class="yao-popup-content" catchtap="true">
      <view class="yao-popup-header">
        <text class="yao-popup-title">{{yaoTypes[selectedYaoIndex]}}</text>
        <text class="yao-popup-type {{selectedYaoType === '老阳' || selectedYaoType === '老阴' ? 'bian' : ''}}">{{selectedYaoType}}</text>
      </view>
      <view class="yao-popup-body">
        <view class="yao-popup-line {{selectedYaoYao === 1 ? 'yang' : 'yin'}}"></view>
        <text class="yao-popup-ci">{{currentTab === 0 ? guaDetail.yaoCi[selectedYaoIndex] : bianGuaDetail.yaoCi[selectedYaoIndex]}}</text>
      </view>
      <view class="yao-popup-close">点击关闭</view>
    </view>
  </view>

  <!-- 复制成功弹窗 -->
  <view class="copy-success-popup" wx:if="{{showCopySuccess}}" bindtap="closeCopySuccess">
    <view class="copy-success-content" catchtap="true">
      <view class="copy-success-icon">✓</view>
      <view class="copy-success-title">复制成功</view>
      <view class="copy-success-desc">可打开以下工具进行解卦：</view>
      <view class="copy-success-list">
        <text class="copy-success-item">豆包</text>
        <text class="copy-success-item">DeepSeek</text>
        <text class="copy-success-item">Qwen（通义千问）</text>
        <text class="copy-success-item">寻访专业人士</text>
      </view>
      <view class="copy-success-tip">或收藏此页面，待日后复盘</view>
      <view class="copy-success-close">点击任意处关闭</view>
    </view>
  </view>
</view>
