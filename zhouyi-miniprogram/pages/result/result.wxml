<!--pages/result/result.wxml-->
<view class="container">
  <!-- 问事信息 -->
  <view class="question-info" wx:if="{{showQuestionInfo && questionInfo}}">
    <view class="question-header">本次问事</view>
    <view class="question-item">
      <text class="question-label">所问何事：</text>
      <text class="question-value">{{questionInfo.event}}</text>
    </view>
    <view class="question-item" wx:if="{{questionInfo.locationText}}">
      <text class="question-label">所在地点：</text>
      <text class="question-value">{{questionInfo.locationText}}</text>
    </view>
    <view class="question-item" wx:if="{{questionInfo.currentTime}}">
      <text class="question-label">当前时间：</text>
      <text class="question-value">{{questionInfo.currentTime}}</text>
    </view>
    <view class="question-item" wx:if="{{questionInfo.targetTime}}">
      <text class="question-label">目标时间：</text>
      <text class="question-value">{{questionInfo.targetTime}}</text>
    </view>
  </view>

  <!-- 卦象显示 -->
  <view class="gua-display">
    <!-- 卦象符号 -->
    <view class="gua-symbol">
      <view class="symbol-text">{{guaDetail.guaName}}</view>
      <view class="symbol-icon">{{guaDetail.lowerGua !== undefined ? (baGua[guaDetail.upperGua].icon + baGua[guaDetail.lowerGua].icon) : ''}}</view>
    </view>

    <!-- 卦名和解释 -->
    <view class="gua-info">
      <view class="gua-name {{currentTab === 1 ? 'bian-gua' : ''}}">{{currentTab === 0 ? guaDetail.guaName : bianGuaDetail.guaName}}卦</view>
      <view class="gua-xiang {{currentTab === 1 ? 'bian-gua' : ''}}">{{currentTab === 0 ? (guaDetail.lowerGua !== undefined ? (baGua[guaDetail.upperGua].name + baGua[guaDetail.lowerGua].name) : guaDetail.guaXiang) : (bianGuaDetail.lowerGua !== undefined ? (baGua[bianGuaDetail.upperGua].name + baGua[bianGuaDetail.lowerGua].name) : bianGuaDetail.guaXiang)}}</view>
    </view>

    <!-- 变卦提示 -->
    <view class="bian-tip" wx:if="{{hasBian}}">
      <text>本卦 {{guaDetail.guaName}} → 变卦 {{bianGuaDetail.guaName}}</text>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar" wx:if="{{hasBian}}">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
      本卦
    </view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
      变卦
    </view>
  </view>

  <!-- 卦象六爻 -->
  <view class="yao-display {{currentTab === 1 ? 'bian-yao-display' : ''}}">
    <view class="yao-title {{currentTab === 1 ? 'bian-gua' : ''}}">六爻</view>
    <view class="yao-list">
      <block wx:for="{{results}}" wx:key="index">
        <view class="yao-item">
          <text class="yao-name">{{yaoTypes[(index + 3) % 6]}}</text>
          <text class="yao-type {{item.type === '老阳' || item.type === '老阴' ? 'bian' : ''}} {{currentTab === 1 ? 'bian-yao' : ''}}">{{item.type}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 卦辞区域 -->
  <view class="content-section">
    <view class="section-title">卦辞</view>
    <view class="section-content gua-ci">
      {{currentTab === 0 ? guaDetail.guaCi : bianGuaDetail.guaCi}}
    </view>
  </view>

  <!-- 彖传 -->
  <view class="content-section">
    <view class="section-title">彖传</view>
    <view class="section-content">
      {{currentTab === 0 ? guaDetail.duan : bianGuaDetail.duan}}
    </view>
  </view>

  <!-- 大象传 -->
  <view class="content-section">
    <view class="section-title">大象传</view>
    <view class="section-content">
      {{currentTab === 0 ? guaDetail.xiang : bianGuaDetail.xiang}}
    </view>
  </view>

  <!-- 爻辞 -->
  <view class="content-section">
    <view class="section-title">爻辞</view>
    <view class="yao-ci-list">
      <block wx:for="{{currentTab === 0 ? guaDetail.yaoCi : bianGuaDetail.yaoCi}}" wx:key="index">
        <view class="yao-ci-item">
          <text class="yao-ci-label">{{yaoTypes[(index + 3) % 6]}}</text>
          <text class="yao-ci-text">{{item}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-btns">
    <button class="copy-btn" bindtap="copyGuaCi">复制卦辞</button>
    <button class="share-btn" open-type="share">分享结果</button>
  </view>
</view>
