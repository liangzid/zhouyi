/* pages/question/question.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(232, 213, 183, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #888;
  transition: all 0.3s ease;
}

.step-item.active .step-dot {
  background: #e8d5b7;
  border-color: #e8d5b7;
  color: #1a1a2e;
}

.step-text {
  font-size: 22rpx;
  color: #666;
  margin-top: 10rpx;
}

.step-item.active .step-text {
  color: #e8d5b7;
}

.step-line {
  width: 60rpx;
  height: 2rpx;
  background: rgba(232, 213, 183, 0.2);
  margin: 0 10rpx;
  margin-bottom: 30rpx;
  transition: all 0.3s ease;
}

.step-line.active {
  background: #e8d5b7;
}

/* 步骤内容 */
.step-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.step-title {
  font-size: 40rpx;
  color: #e8d5b7;
  text-align: center;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.step-tip {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  margin-bottom: 30rpx;
}

.location-tip,
.target-tip {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 输入区域 */
.input-area {
  margin-bottom: 40rpx;
}

.event-input {
  width: 100%;
  height: 90rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(232, 213, 183, 0.3);
  border-radius: 12rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  color: #e8d5b7;
  box-sizing: border-box;
}

.event-input::placeholder {
  color: #666;
}

/* 快捷选择 */
.quick-select {
  margin-bottom: 60rpx;
}

.quick-label {
  font-size: 26rpx;
  color: #888;
  display: block;
  margin-bottom: 20rpx;
}

.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.quick-tag {
  padding: 15rpx 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(232, 213, 183, 0.3);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #888;
}

.quick-tag.active {
  background: rgba(232, 213, 183, 0.2);
  border-color: #e8d5b7;
  color: #e8d5b7;
}

/* 地址 */
.location-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.location-btn {
  width: 300rpx;
  height: 90rpx;
  background: rgba(232, 213, 183, 0.15);
  border: 2rpx solid #e8d5b7;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.location-btn text {
  font-size: 28rpx;
  color: #e8d5b7;
}

.location-result {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.location-text {
  font-size: 28rpx;
  color: #e8d5b7;
  margin-bottom: 20rpx;
}

.location-change {
  padding: 10rpx 20rpx;
  border: 1rpx solid rgba(232, 213, 183, 0.3);
  border-radius: 20rpx;
}

.location-change text {
  font-size: 24rpx;
  color: #888;
}

/* 时间 */
.time-display {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
}

.time-label {
  font-size: 28rpx;
  color: #888;
}

.time-value {
  font-size: 32rpx;
  color: #e8d5b7;
}

.time-toggle {
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx;
}

.switch-label {
  display: flex;
  align-items: center;
}

.switch {
  width: 80rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(232, 213, 183, 0.3);
  position: relative;
  margin-right: 20rpx;
}

.switch::after {
  content: '';
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #888;
  top: 3rpx;
  left: 3rpx;
  transition: all 0.3s;
}

.switch.active {
  background: rgba(232, 213, 183, 0.2);
  border-color: #e8d5b7;
}

.switch.active::after {
  left: 41rpx;
  background: #e8d5b7;
}

.switch-label text {
  font-size: 28rpx;
  color: #888;
}

/* 目标时间示例 */
.target-examples {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.example {
  color: #e8d5b7;
  margin: 0 10rpx;
}

/* 算卦区域 */
.divination-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
}

.coin-animation {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.coin {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e8d5b7 0%, #c9a86c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 20rpx auto;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.3);
}

.coin-text {
  font-size: 60rpx;
  color: #1a1a2e;
  font-weight: bold;
}

.start-btn {
  width: 280rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #e8d5b7 0%, #c9a86c 100%);
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(232, 213, 183, 0.3);
}

.start-btn text {
  font-size: 34rpx;
  color: #1a1a2e;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.start-btn.disabled {
  background: #444;
  box-shadow: none;
}

.start-btn.disabled text {
  color: #888;
}

/* 按钮区域 */
.action-btns {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: auto;
  padding-top: 60rpx;
}

.prev-btn,
.next-btn {
  width: 200rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.prev-btn {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(232, 213, 183, 0.3);
}

.prev-btn text {
  font-size: 28rpx;
  color: #888;
}

.next-btn {
  background: linear-gradient(135deg, #e8d5b7 0%, #c9a86c 100%);
}

.next-btn text {
  font-size: 28rpx;
  color: #1a1a2e;
  font-weight: bold;
}
